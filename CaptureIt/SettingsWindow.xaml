<Window x:Class="CaptureIt.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings.Title}" Height="670" Width="470"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBg}"
        FontFamily="Malgun Gothic" UseLayoutRounding="True">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,6,0">

                <!-- 일반 -->
                <TextBlock Text="{DynamicResource Settings.General}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextMain}"/>
                <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="12" Margin="0,8,0,16"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Language}" FontSize="12"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSub}"/>
                            <ComboBox x:Name="CmbLanguage" Grid.Column="1" Width="150" HorizontalAlignment="Left"
                                      Margin="12,0,0,0" FontSize="12">
                                <ComboBoxItem Content="한국어"/>
                                <ComboBoxItem Content="English"/>
                            </ComboBox>
                        </Grid>
                        <CheckBox x:Name="ChkStartup" Content="{DynamicResource Settings.RunAtStartup}" FontSize="12" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 저장 위치 -->
                <TextBlock Text="{DynamicResource Settings.SaveLocation}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextMain}"/>
                <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="12" Margin="0,8,0,16"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtFolder" Grid.Column="0" Padding="6,5" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                    Margin="8,0,0,0" Click="Browse_Click">
                                <TextBlock Text="{DynamicResource Settings.Browse}"/>
                            </Button>
                        </Grid>
                        <!-- 라벨·입력란은 고정 폭, 예시 문구는 남는 폭을 쓴다 (영어에서도 안 잘리게) -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.FilePrefix}" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSub}"/>
                            <TextBox x:Name="TxtPrefix" Grid.Column="1" Width="110" Margin="8,0,0,0" Padding="5,4"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Settings.PrefixExample}" FontSize="11" VerticalAlignment="Center"
                                       Foreground="#A5ADBB" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 파일 형식 -->
                <TextBlock Text="{DynamicResource Settings.Format}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextMain}"/>
                <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="12" Margin="0,8,0,16"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                    <!-- 창 폭이 고정(470)이라 영어 라벨이 한 줄에 안 들어간다: 넘치면 다음 줄로 -->
                    <WrapPanel Orientation="Horizontal">
                        <RadioButton x:Name="FmtPng" Content="{DynamicResource Settings.FmtPng}" GroupName="Fmt" IsChecked="True" FontSize="12" Margin="0,0,16,4"/>
                        <RadioButton x:Name="FmtJpg" Content="{DynamicResource Settings.FmtJpg}" GroupName="Fmt" FontSize="12" Margin="0,0,16,4"/>
                        <RadioButton x:Name="FmtBmp" Content="BMP" GroupName="Fmt" FontSize="12" Margin="0,0,0,4"/>
                    </WrapPanel>
                </Border>

                <!-- 캡처 후 동작 -->
                <TextBlock Text="{DynamicResource Settings.AfterCapture}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextMain}"/>
                <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="12" Margin="0,8,0,16"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                    <StackPanel>
                        <RadioButton x:Name="ActEditor" GroupName="Act" IsChecked="True" FontSize="12"
                                     Content="{DynamicResource Settings.ActEditor}"/>
                        <RadioButton x:Name="ActSave" GroupName="Act" Margin="0,8,0,0" FontSize="12"
                                     Content="{DynamicResource Settings.ActSave}"/>
                        <RadioButton x:Name="ActCopy" GroupName="Act" Margin="0,8,0,0" FontSize="12"
                                     Content="{DynamicResource Settings.ActCopy}"/>
                    </StackPanel>
                </Border>

                <!-- 기타 -->
                <TextBlock Text="{DynamicResource Settings.Etc}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextMain}"/>
                <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="12" Margin="0,8,0,16"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox x:Name="ChkClipboard" Content="{DynamicResource Settings.AlwaysClipboard}" FontSize="12"/>
                        <CheckBox x:Name="ChkHide" Content="{DynamicResource Settings.HideOnCapture}" FontSize="12" Margin="0,8,0,0"/>
                        <CheckBox x:Name="ChkSound" Content="{DynamicResource Settings.Sound}" FontSize="12" Margin="0,8,0,0"/>
                        <CheckBox x:Name="ChkTray" Content="{DynamicResource Settings.TrayIcon}" FontSize="12" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 단축키 (클릭 후 키 조합 입력으로 변경) -->
                <TextBlock Text="{DynamicResource Settings.Hotkeys}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextMain}"/>
                <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="12" Margin="0,8,0,4"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.Resources>
                                <Style x:Key="HotkeyBox" TargetType="TextBox">
                                    <Setter Property="Width" Value="128"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="IsReadOnly" Value="True"/>
                                    <Setter Property="IsReadOnlyCaretVisible" Value="False"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0" Grid.Column="0" x:Name="HkRegion" Style="{StaticResource HotkeyBox}" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource Settings.HotkeyRegion}" FontSize="12" Margin="16,0,0,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="0" x:Name="HkElement" Style="{StaticResource HotkeyBox}" Margin="0,6,0,0" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{DynamicResource Settings.HotkeyElement}" FontSize="12" Margin="16,6,0,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="0" x:Name="HkWindow" Style="{StaticResource HotkeyBox}" Margin="0,6,0,0" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{DynamicResource Settings.HotkeyWindow}" FontSize="12" Margin="16,6,0,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="0" x:Name="HkFull" Style="{StaticResource HotkeyBox}" Margin="0,6,0,0" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{DynamicResource Settings.HotkeyFull}" FontSize="12" Margin="16,6,0,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="0" x:Name="HkScroll" Style="{StaticResource HotkeyBox}" Margin="0,6,0,0" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{DynamicResource Settings.HotkeyScroll}" FontSize="12" Margin="16,6,0,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="5" Grid.Column="0" x:Name="HkFixed" Style="{StaticResource HotkeyBox}" Margin="0,6,0,0" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{DynamicResource Settings.HotkeyFixed}" FontSize="12" Margin="16,6,0,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="6" Grid.Column="0" x:Name="HkRepeat" Style="{StaticResource HotkeyBox}" Margin="0,6,0,0" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{DynamicResource Settings.HotkeyRepeat}" FontSize="12" Margin="16,6,0,0" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- PrintScreen은 조합을 바꿀 수 없는 고정 키라 사용/해제만 있는 체크박스로 둔다 -->
                        <CheckBox x:Name="ChkPrintScreen" Content="{DynamicResource Settings.HotkeyPrintScreen}"
                                  FontSize="12" Margin="0,12,0,0"
                                  Checked="PrintScreen_Toggled" Unchecked="PrintScreen_Toggled"/>
                        <!-- Windows가 PrtSc를 캡처 도구에 쓰고 있을 때만 안내 + 설정 열기 버튼을 보여준다 -->
                        <StackPanel x:Name="PrtScClaimedPanel" Visibility="Collapsed" Margin="24,6,0,0">
                            <TextBlock Text="{DynamicResource Settings.PrintScreenClaimed}" FontSize="11"
                                       Foreground="{StaticResource TextMain}" TextWrapping="Wrap"/>
                            <Button Style="{StaticResource GhostButton}" Padding="10,5" Margin="0,6,0,0"
                                    HorizontalAlignment="Left" Click="OpenWinKeyboard_Click">
                                <TextBlock Text="{DynamicResource Settings.OpenWindowsKeyboard}" FontSize="12"/>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Settings.HotkeyHint}" FontSize="11"
                                   Foreground="{StaticResource TextSub}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 업데이트 -->
                <TextBlock Text="{DynamicResource Settings.Updates}" FontWeight="Bold" FontSize="13"
                           Foreground="{StaticResource TextMain}" Margin="0,12,0,0"/>
                <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="12" Margin="0,8,0,4"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox x:Name="ChkAutoUpdate" Content="{DynamicResource Settings.AutoUpdate}" FontSize="12"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- 상태 메시지가 길어도 확인 버튼 아래로 파고들지 않게 별도 열 + 줄바꿈.
                                 메시지가 없을 때는 줄 자체를 접어 카드 높이가 늘지 않게 한다 -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock x:Name="TxtCurrentVersion" FontSize="12"
                                           Foreground="{StaticResource TextSub}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtUpdateStatus" FontSize="12" Margin="0,2,0,0"
                                           Foreground="{StaticResource PrimaryBrush}" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button x:Name="BtnCheckNow" Grid.Column="1" Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Click="CheckNow_Click"
                                    Content="{DynamicResource Settings.CheckNow}" FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource GhostButton}" Width="88" Click="Cancel_Click">
                <TextBlock Text="{DynamicResource Settings.Cancel}"/>
            </Button>
            <Button Style="{StaticResource AccentButton}" Width="88" Margin="10,0,0,0" Click="Save_Click">
                <TextBlock Text="{DynamicResource Settings.Save}"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
