<Window x:Class="CaptureIt.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Editor.Title}" Height="820" Width="1500"
        MinHeight="480" MinWidth="900"
        Background="{StaticResource WindowBg}"
        FontFamily="Malgun Gothic" UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ══ 도구 모음 ══ -->
        <Border Grid.Row="0" Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1" Padding="10,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 도구 모음은 우측 저장 버튼과 다른 열에 둔다. 창이 좁아져도 버튼을
                     밀어내지 않고 가로 스크롤로 모든 도구에 접근한다 -->
                <ScrollViewer Grid.Column="0" Focusable="False"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">

                    <!-- 메인 창 다시 보기: 캡처 후 편집기만 남으면 툴바를 못 찾는 경우가 많아
                         맨 왼쪽(도구 표시 여부와 무관하게 위치가 고정되는 자리)에 둔다 -->
                    <Button x:Name="BtnMainWindow" Style="{StaticResource GhostButton}" Padding="10,6"
                            Click="ShowMain_Click" ToolTip="{DynamicResource Editor.Tip.MainWindow}"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                        <StackPanel>
                            <Path Data="M4,2 L14,2 L14,10 M2,5 L12,5 L12,14 L2,14 Z M2,8 L12,8"
                                  Stroke="{StaticResource TextMain}" StrokeThickness="1.5" Fill="Transparent"
                                  Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Editor.MainWindow}" FontSize="10" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 새 캡처 -->
                    <Button x:Name="BtnNewCapture" Style="{StaticResource AccentButton}" Padding="12,6"
                            Click="NewCapture_Click" ToolTip="{DynamicResource Editor.Tip.NewCapture}"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Path Data="M2,4 L2,2 L5,2 M11,2 L14,2 L14,4 M14,12 L14,14 L11,14 M5,14 L2,14 L2,12 M8,5 L8,11 M5,8 L11,8"
                                  Stroke="White" StrokeThickness="1.6" Fill="Transparent"
                                  Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Editor.NewCapture}" FontSize="10" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="42" Fill="{StaticResource BorderSoft}" Margin="8,0"/>

                    <!-- 그리기 도구 -->
                    <RadioButton x:Name="ToolSelect" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Select" IsChecked="True" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Select}">
                        <StackPanel MinWidth="38">
                            <Path Data="M4,1 L4,15 L8,11 L11,17 L13,16 L10,10 L15,10 Z" Fill="Transparent"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.4" Width="16" Height="17" Stretch="Uniform"/>
                            <TextBlock Text="{DynamicResource Editor.Select}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolPen" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Pen" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Pen}">
                        <StackPanel MinWidth="38">
                            <Path Data="M2,16 L3,12 L12,3 C13,2 15,2 16,3 C17,4 17,6 16,7 L7,16 L2,17 Z M11,4 L15,8"
                                  Fill="Transparent"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.4" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{DynamicResource Editor.Pen}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolHighlight" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Highlight" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Highlight}">
                        <StackPanel MinWidth="38">
                            <Path Data="M3,14 L11,6 L14,9 L6,17 Z M11,6 L13,2 L18,7 L14,9 Z"
                                  Fill="Transparent"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.4" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{DynamicResource Editor.Highlight}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolLine" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Line" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Line}">
                        <StackPanel MinWidth="38">
                            <Path Data="M2,15 L15,2"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.8" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{DynamicResource Editor.Line}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolArrow" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Arrow" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Arrow}">
                        <StackPanel MinWidth="38">
                            <Path Data="M2,15 L14,3 M14,3 L8,4 M14,3 L13,9"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.8" Width="16" Height="16" Stretch="Uniform" Fill="Transparent"/>
                            <TextBlock Text="{DynamicResource Editor.Arrow}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolRect" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Rect" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Rect}">
                        <StackPanel MinWidth="38">
                            <Rectangle Width="16" Height="12" RadiusX="2" RadiusY="2"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                       StrokeThickness="1.6" Fill="Transparent" Margin="0,2"/>
                            <TextBlock Text="{DynamicResource Editor.Rect}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolEllipse" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Ellipse" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Ellipse}">
                        <StackPanel MinWidth="38">
                            <Ellipse Width="16" Height="12"
                                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                     StrokeThickness="1.6" Fill="Transparent" Margin="0,2"/>
                            <TextBlock Text="{DynamicResource Editor.Ellipse}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolText" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Text" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Text}">
                        <StackPanel MinWidth="38">
                            <TextBlock Text="T" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Height="16"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            <TextBlock Text="{DynamicResource Editor.Text}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolNumber" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Number" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Number}">
                        <StackPanel MinWidth="38">
                            <Grid Width="16" Height="16">
                                <Ellipse Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                         StrokeThickness="1.5"/>
                                <TextBlock Text="1" FontSize="9.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            </Grid>
                            <TextBlock Text="{DynamicResource Editor.Number}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolMosaic" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Mosaic" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Mosaic}">
                        <StackPanel MinWidth="38">
                            <Canvas Width="16" Height="16">
                                <Rectangle Canvas.Left="0" Canvas.Top="0" Width="5" Height="5" Fill="#88888888"/>
                                <Rectangle Canvas.Left="10" Canvas.Top="0" Width="5" Height="5" Fill="#BB888888"/>
                                <Rectangle Canvas.Left="5" Canvas.Top="5" Width="5" Height="5" Fill="#66888888"/>
                                <Rectangle Canvas.Left="0" Canvas.Top="10" Width="5" Height="5" Fill="#BB888888"/>
                                <Rectangle Canvas.Left="10" Canvas.Top="10" Width="5" Height="5" Fill="#88888888"/>
                            </Canvas>
                            <TextBlock Text="{DynamicResource Editor.Mosaic}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolEraser" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Eraser" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Eraser}">
                        <StackPanel MinWidth="38">
                            <Path Data="M6,13 L1.8,8.8 C1,8 1,6.8 1.8,6 L6.8,1 C7.6,0.2 8.8,0.2 9.6,1 L14,5.4 C14.8,6.2 14.8,7.4 14,8.2 L9.2,13 Z M3.5,11 L8,6.5 M2,15 L14,15"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.4" Fill="Transparent" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{DynamicResource Editor.Eraser}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ToolCrop" Style="{StaticResource ToolToggle}" GroupName="Tool"
                                 Tag="Crop" Checked="Tool_Checked" ToolTip="{DynamicResource Editor.Tip.Crop}">
                        <StackPanel MinWidth="38">
                            <Path Data="M4,0 L4,13 L17,13 M0,4 L13,4 L13,17"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.6" Width="16" Height="16" Stretch="Uniform" Fill="Transparent"/>
                            <TextBlock Text="{DynamicResource Editor.Crop}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <Rectangle Width="1" Height="42" Fill="{StaticResource BorderSoft}" Margin="7,0"/>

                    <!-- 색상 -->
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#EF4444" Tag="#EF4444" IsChecked="True" Checked="Color_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#F97316" Tag="#F97316" Checked="Color_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#FACC15" Tag="#FACC15" Checked="Color_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#22C55E" Tag="#22C55E" Checked="Color_Checked"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#2D7DF6" Tag="#2D7DF6" Checked="Color_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#8B5CF6" Tag="#8B5CF6" Checked="Color_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#111827" Tag="#111827" Checked="Color_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#FFFFFF" Tag="#FFFFFF" Checked="Color_Checked"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 굵기: 실제 선 두께 미리보기로 선택 -->
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="{DynamicResource Editor.Thickness}" FontSize="10" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center"/>
                        <ComboBox x:Name="CmbThickness" Width="76" FontSize="11" Margin="0,3,0,0"
                                  SelectionChanged="Thickness_Changed"/>
                    </StackPanel>

                    <!-- 채우기 색: 사각형/원 도구에서만 표시 -->
                    <StackPanel x:Name="FillGroup" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource Editor.Fill}" FontSize="9" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Fill" Background="{StaticResource CheckerBrush}"
                                         Tag="transparent" IsChecked="True" Checked="Fill_Checked" ToolTip="{DynamicResource Editor.FillNone}"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Fill" Background="#EF4444" Tag="#EF4444" Checked="Fill_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Fill" Background="#F97316" Tag="#F97316" Checked="Fill_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Fill" Background="#FACC15" Tag="#FACC15" Checked="Fill_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Fill" Background="#22C55E" Tag="#22C55E" Checked="Fill_Checked"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Fill" Background="#2D7DF6" Tag="#2D7DF6" Checked="Fill_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Fill" Background="#8B5CF6" Tag="#8B5CF6" Checked="Fill_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Fill" Background="#111827" Tag="#111827" Checked="Fill_Checked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Fill" Background="#FFFFFF" Tag="#FFFFFF" Checked="Fill_Checked"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 글꼴/크기: 텍스트 도구에서만 표시. 입력 중인 텍스트박스에 즉시 반영 -->
                    <StackPanel x:Name="TextGroup" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource Editor.Font}" FontSize="9" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <ComboBox x:Name="CmbFont" Width="128" FontSize="11" SelectionChanged="Font_Changed"/>
                            <ComboBox x:Name="CmbFontSize" Width="56" FontSize="11" Margin="6,0,0,0"
                                      IsEditable="True" SelectionChanged="FontSize_Changed"
                                      PreviewKeyDown="FontSize_KeyDown" LostFocus="FontSize_LostFocus"/>
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Width="1" Height="42" Fill="{StaticResource BorderSoft}" Margin="7,0"/>

                    <!-- 실행 취소/다시 실행/초기화 -->
                    <Button x:Name="BtnUndo" Style="{StaticResource IconButton}" Click="Undo_Click" ToolTip="{DynamicResource Editor.Tip.Undo}" VerticalAlignment="Center">
                        <Path Data="M7,3 L2,8 L7,13 M2,8 L11,8 C14,8 16,10 16,13"
                              Stroke="{StaticResource TextSub}" StrokeThickness="1.7" Fill="Transparent"
                              Width="16" Height="14" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="BtnRedo" Style="{StaticResource IconButton}" Click="Redo_Click" ToolTip="{DynamicResource Editor.Tip.Redo}" VerticalAlignment="Center">
                        <Path Data="M11,3 L16,8 L11,13 M16,8 L7,8 C4,8 2,10 2,13"
                              Stroke="{StaticResource TextSub}" StrokeThickness="1.7" Fill="Transparent"
                              Width="16" Height="14" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="BtnReset" Style="{StaticResource IconButton}" Click="Reset_Click" ToolTip="{DynamicResource Editor.Tip.Reset}" VerticalAlignment="Center">
                        <!-- 초기화(되돌리기) 아이콘: 반시계 방향 원형 화살표.
                             Stretch를 쓰지 않아 좌표가 픽셀과 1:1로 대응한다 (Undo/Redo와 같은 무게) -->
                        <Canvas Width="16" Height="16">
                            <!-- 원호: 중심(8,8.1) 반지름 6, 12시→3시→6시→9시 270° (좌상단 사분면을 비움).
                                 사분원 베지어 제어점 오프셋 k = 0.5523 × 6 = 3.31 -->
                            <Path Data="M8,2.1 C11.31,2.1 13.9,4.79 13.9,8.1 C13.9,11.41 11.31,14.1 8,14.1 C4.69,14.1 2.1,11.41 2.1,8.1"
                                  Stroke="{StaticResource TextSub}" StrokeThickness="1.6" Fill="Transparent"/>
                            <!-- 화살촉: 12시 끝점의 반시계 접선(-X 방향)에 좌우 완전 대칭.
                                 밑변 중심(8.3,2.1) · 길이 4.4 · 밑변 폭 4.2 -->
                            <Path Data="M3.9,2.1 L8.3,0 L8.3,4.2 Z" Fill="{StaticResource TextSub}"/>
                        </Canvas>
                    </Button>
                </StackPanel>
                </ScrollViewer>

                <!-- 우측: 저장/복사 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnCopy" Style="{StaticResource GhostButton}" Click="Copy_Click" ToolTip="{DynamicResource Editor.Tip.Copy}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M5,1 L13,1 L13,11 L5,11 Z M3,4 L3,14 L11,14"
                                  Stroke="{StaticResource TextMain}" StrokeThickness="1.5" Fill="Transparent"
                                  Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Editor.Copy}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSaveAs" Style="{StaticResource GhostButton}" Click="SaveAs_Click" Margin="8,0,0,0"
                            ToolTip="{DynamicResource Editor.Tip.SaveAs}">
                        <TextBlock Text="{DynamicResource Editor.SaveAs}"/>
                    </Button>
                    <Button x:Name="BtnSave" Style="{StaticResource AccentButton}" Click="Save_Click" Margin="8,0,0,0"
                            ToolTip="{DynamicResource Editor.Tip.Save}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M8,1 L8,10 M4,6 L8,10 L12,6 M2,13 L14,13"
                                  Stroke="White" StrokeThickness="1.7" Fill="Transparent"
                                  Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Editor.Save}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ 본문: 캔버스 + 캡처 목록 사이드바 ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="236"/>
            </Grid.ColumnDefinitions>

            <!-- 캔버스 -->
            <Grid Grid.Column="0">
                <ScrollViewer x:Name="Scroller"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Background="#EDF0F5" Focusable="False"
                              PreviewMouseWheel="Scroller_MouseWheel">
                    <Grid x:Name="CanvasHost" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                        <Grid.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="1" Opacity="0.25" Color="#1F2937"/>
                        </Grid.Effect>
                        <Image x:Name="BaseImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Canvas x:Name="DrawCanvas" Background="Transparent"
                                MouseLeftButtonDown="Canvas_MouseDown"
                                MouseMove="Canvas_MouseMove"
                                MouseLeftButtonUp="Canvas_MouseUp"/>
                    </Grid>
                </ScrollViewer>
                <!-- 빈 상태 -->
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed" IsHitTestVisible="False">
                    <Canvas Width="56" Height="56" HorizontalAlignment="Center" Opacity="0.35">
                        <Rectangle Canvas.Left="4" Canvas.Top="8" Width="48" Height="40" RadiusX="6" RadiusY="6"
                                   Stroke="{StaticResource TextSub}" StrokeThickness="2.4" StrokeDashArray="3 2.2"/>
                        <Path Data="M28,20 L28,36 M20,28 L36,28" Stroke="{StaticResource TextSub}" StrokeThickness="2.4"/>
                    </Canvas>
                    <TextBlock Text="{DynamicResource Editor.Empty}" FontSize="13" Foreground="{StaticResource TextSub}"
                               TextAlignment="Center" Margin="0,14,0,0" LineHeight="22"/>
                </StackPanel>
            </Grid>

            <!-- 캡처 목록 사이드바: 최근 캡처를 항상 곁에 두고 즉시 전환·편집 -->
            <Border Grid.Column="1" Background="{StaticResource CardBg}"
                    BorderBrush="{StaticResource BorderSoft}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <StackPanel Grid.Row="0" Margin="14,12,14,8">
                        <TextBlock Text="{DynamicResource History.Title}" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource TextMain}"/>
                        <TextBlock x:Name="LblSidebarCount" Text="0 / 100" FontSize="11"
                                   Foreground="{StaticResource TextSub}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- 목록 -->
                    <ListBox x:Name="HistoryList" Grid.Row="1" BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="HistoryList_SelectionChanged"
                             KeyDown="HistoryList_KeyDown"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="10,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="White" CornerRadius="8"
                                                    BorderBrush="{StaticResource BorderSoft}" BorderThickness="1.4"
                                                    Padding="5">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#9CC1F7"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel>
                                        <Border CornerRadius="5" Background="#F0F2F6" Height="108" ClipToBounds="True">
                                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" StretchDirection="DownOnly"/>
                                        </Border>
                                        <TextBlock Text="{Binding Caption}" FontSize="10.5"
                                                   Foreground="{StaticResource TextSub}" Margin="2,4,0,1"/>
                                    </StackPanel>
                                    <!-- 삭제 버튼 (호버 시 표시) -->
                                    <Button x:Name="BtnDelItem" Click="HistoryDelete_Click" Tag="{Binding}"
                                            Width="20" Height="20" Cursor="Hand"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                                            Visibility="Collapsed" ToolTip="{DynamicResource History.Delete}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#B31F2937" CornerRadius="10">
                                                    <Path Data="M0,0 L6,6 M6,0 L0,6" Stroke="White" StrokeThickness="1.4"
                                                          Width="6" Height="6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="BtnDelItem" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource History.CopyItem}" Click="HistoryCopy_Click"/>
                                <MenuItem Header="{DynamicResource History.SaveItem}" Click="HistorySaveOne_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource History.Delete}" Click="HistoryDeleteSelected_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>

                    <!-- 빈 목록 안내 -->
                    <TextBlock x:Name="SidebarEmpty" Grid.Row="1" Text="{DynamicResource History.Empty}"
                               FontSize="12" Foreground="#A5ADBB" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>

                    <!-- 푸터 -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,1,0,0" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource GhostButton}" Padding="8,6" Margin="0,0,4,0"
                                    Click="HistorySaveAll_Click">
                                <TextBlock Text="{DynamicResource History.SaveAll}" FontSize="11"/>
                            </Button>
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Padding="8,6" Margin="4,0,0,0"
                                    Click="HistoryDeleteAll_Click">
                                <TextBlock Text="{DynamicResource History.DeleteAll}" FontSize="11" Foreground="{StaticResource DangerBrush}"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ 상태 바 ══ -->
        <Border Grid.Row="2" Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtImgSize" FontSize="11" Foreground="{StaticResource TextSub}"/>
                    <TextBlock Text="  ·  " FontSize="11" Foreground="{StaticResource TextSub}"/>
                    <TextBlock x:Name="TxtZoom" FontSize="11" Foreground="{StaticResource TextSub}" Text="100%"/>
                    <TextBlock Text="  " FontSize="11"/>
                    <TextBlock Text="{DynamicResource Editor.ZoomHint}" FontSize="11" Foreground="#A5ADBB"/>
                </StackPanel>
                <TextBlock x:Name="TxtStatus" FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
