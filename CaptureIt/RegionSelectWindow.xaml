<Window x:Class="CaptureIt.RegionSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True" WindowStartupLocation="Manual"
        Cursor="Cross" FontFamily="Malgun Gothic" UseLayoutRounding="True"
        KeyDown="Window_KeyDown">
    <Grid x:Name="Root">
        <!-- 정지된 화면 -->
        <Image x:Name="FrozenImage" Stretch="Fill"/>

        <!-- 어두운 오버레이 (선택 영역만 구멍) -->
        <Path x:Name="DimPath" Fill="#66000000"/>

        <!-- 십자선 (드래그 전) -->
        <Line x:Name="CrossH" Stroke="#B0FFFFFF" StrokeThickness="1" StrokeDashArray="4 3" Visibility="Collapsed"/>
        <Line x:Name="CrossV" Stroke="#B0FFFFFF" StrokeThickness="1" StrokeDashArray="4 3" Visibility="Collapsed"/>

        <!-- 선택 테두리 -->
        <Rectangle x:Name="SelRect" Stroke="#2D7DF6" StrokeThickness="2"
                   Fill="Transparent" Visibility="Collapsed"
                   HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- 크기 라벨 -->
        <Border x:Name="SizeLabel" Background="#E61F2937" CornerRadius="6" Padding="8,4"
                HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Collapsed">
            <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
        </Border>

        <!-- 창 캡처: 창 제목 라벨 -->
        <Border x:Name="TitleLabel" Background="#E62D7DF6" CornerRadius="6" Padding="10,5"
                HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Collapsed">
            <TextBlock x:Name="TitleText" Foreground="White" FontSize="12" FontWeight="SemiBold"
                       MaxWidth="420" TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- 상단 안내 -->
        <Border x:Name="HintBar" Background="#D91F2937" CornerRadius="10" Padding="18,9"
                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,28,0,0">
            <TextBlock x:Name="HintText" Foreground="White" FontSize="13"/>
        </Border>
    </Grid>
</Window>
