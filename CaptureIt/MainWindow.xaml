<Window x:Class="CaptureIt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource App.Name}" Height="156" Width="836"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="Manual"
        FontFamily="Malgun Gothic" UseLayoutRounding="True">
    <!-- 둥근 모서리 카드. WindowStyle=None + 투명 배경에서는 창 밖으로 번지는 DropShadow가
         창 사각형에서 잘려 네 꼭짓점에 회색 쐐기로 남는다(레이어드 창의 알파 클리핑).
         그래서 그림자는 쓰지 않고 옅은 테두리로만 구분한다. -->
    <Border Background="{StaticResource CardBg}" CornerRadius="14"
            BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="22"/>
            </Grid.RowDefinitions>

            <!-- ── 타이틀 바 ── -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseDown" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <!-- 앱 아이콘(app.ico)과 동일한 카메라 로고 (벡터 재현) -->
                    <Border Width="22" Height="22" CornerRadius="5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0.6,1">
                                <GradientStop Color="#3F8CF8" Offset="0"/>
                                <GradientStop Color="#1E5FCC" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Canvas>
                            <Border Canvas.Left="8.1" Canvas.Top="4.9" Width="5.8" Height="3.6"
                                    Background="White" CornerRadius="1.2,1.2,0,0"/>
                            <Border Canvas.Left="3.5" Canvas.Top="7.2" Width="15" Height="10"
                                    Background="White" CornerRadius="2.6"/>
                            <Ellipse Canvas.Left="7.2" Canvas.Top="8.9" Width="6.6" Height="6.6" Fill="#1B57C9"/>
                            <Ellipse Canvas.Left="8.3" Canvas.Top="9.9" Width="2.5" Height="2.5" Fill="#7FB0F7"/>
                            <Ellipse Canvas.Left="14.9" Canvas.Top="8.9" Width="2" Height="2" Fill="#FACC15"/>
                        </Canvas>
                    </Border>
                    <TextBlock Text="{DynamicResource App.Name}" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource TextMain}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource App.Tagline}" FontSize="11"
                               Foreground="{StaticResource TextSub}" Margin="8,1,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                    <ToggleButton x:Name="BtnPin" Cursor="Hand" Checked="Pin_Changed" Unchecked="Pin_Changed"
                                  ToolTip="{DynamicResource Main.Tip.Pin}" Background="Transparent" BorderThickness="0">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="6">
                                    <Path x:Name="pinIcon"
                                          Data="M8,1 L13,6 L11,8 L11,11 L8,14 L5.5,10.5 L2,14 L1,13 L4.5,9.5 L1,7 L4,4 L6,4 Z"
                                          Stroke="{StaticResource TextSub}" StrokeThickness="1.4" Fill="Transparent"
                                          Width="14" Height="14" Stretch="Uniform"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#EDF1F7"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="pinIcon" Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter TargetName="pinIcon" Property="Stroke" Value="{StaticResource PrimaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <Button Style="{StaticResource IconButton}" Click="About_Click" ToolTip="{DynamicResource Main.Tip.About}">
                        <Grid Width="14" Height="14">
                            <Ellipse Stroke="{StaticResource TextSub}" StrokeThickness="1.4"/>
                            <TextBlock Text="i" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextSub}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Click="Minimize_Click" ToolTip="{DynamicResource Main.Tip.Minimize}">
                        <Path Data="M0,0 L10,0" Stroke="{StaticResource TextSub}" StrokeThickness="1.6"
                              Width="10" Height="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Click="Close_Click" ToolTip="{DynamicResource Main.Tip.Close}">
                        <Path Data="M0,0 L9,9 M9,0 L0,9" Stroke="{StaticResource TextSub}" StrokeThickness="1.6"
                              Width="9" Height="9"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── 캡처 버튼 영역 ── -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- 영역 캡처 -->
                <Button x:Name="BtnRegion" Style="{StaticResource CaptureButton}" Padding="8,3"
                        Click="RegionCapture_Click" ToolTip="{DynamicResource Main.Tip.Region}">
                    <StackPanel MinWidth="66">
                        <Canvas Width="30" Height="30">
                            <Rectangle Canvas.Left="2" Canvas.Top="4" Width="26" Height="22" RadiusX="3" RadiusY="3"
                                       Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8" StrokeDashArray="2.2 1.6"/>
                            <Path Data="M15,10 L15,20 M10,15 L20,15" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8"/>
                        </Canvas>
                        <TextBlock Text="{DynamicResource Main.Region}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        <TextBlock x:Name="LblRegionKey" Text="-" FontSize="10" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,1,0,0" MaxWidth="86" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Button>

                <!-- 단위 영역 -->
                <Button x:Name="BtnElement" Style="{StaticResource CaptureButton}" Padding="8,3"
                        Click="ElementCapture_Click" ToolTip="{DynamicResource Main.Tip.Element}">
                    <StackPanel MinWidth="66">
                        <Canvas Width="30" Height="30">
                            <Rectangle Canvas.Left="2" Canvas.Top="4" Width="26" Height="22" RadiusX="3" RadiusY="3"
                                       Stroke="#9AA6B8" StrokeThickness="1.6"/>
                            <Rectangle Canvas.Left="6" Canvas.Top="8" Width="12" Height="9" RadiusX="1.5" RadiusY="1.5"
                                       Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8" Fill="#E8F1FE"/>
                            <Path Data="M18,15 L18,26 L21,23 L23,27 L25,26 L23,22 L27,22 Z"
                                  Fill="{StaticResource PrimaryBrush}" Stroke="White" StrokeThickness="0.8"/>
                        </Canvas>
                        <TextBlock Text="{DynamicResource Main.Element}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        <TextBlock x:Name="LblElementKey" Text="-" FontSize="10" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,1,0,0" MaxWidth="86" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Button>

                <!-- 창 캡처 -->
                <Button x:Name="BtnWindow" Style="{StaticResource CaptureButton}" Padding="8,3"
                        Click="WindowCapture_Click" ToolTip="{DynamicResource Main.Tip.Window}">
                    <StackPanel MinWidth="66">
                        <Canvas Width="30" Height="30">
                            <Rectangle Canvas.Left="3" Canvas.Top="5" Width="24" Height="20" RadiusX="3" RadiusY="3"
                                       Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8"/>
                            <Line X1="3" Y1="11" X2="27" Y2="11" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8"/>
                            <Ellipse Canvas.Left="6" Canvas.Top="7.2" Width="2.5" Height="2.5" Fill="{StaticResource PrimaryBrush}"/>
                            <Ellipse Canvas.Left="10" Canvas.Top="7.2" Width="2.5" Height="2.5" Fill="{StaticResource PrimaryBrush}"/>
                        </Canvas>
                        <TextBlock Text="{DynamicResource Main.Window}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        <TextBlock x:Name="LblWindowKey" Text="-" FontSize="10" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,1,0,0" MaxWidth="86" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Button>

                <!-- 전체 캡처 -->
                <Button x:Name="BtnFull" Style="{StaticResource CaptureButton}" Padding="8,3"
                        Click="FullCapture_Click" ToolTip="{DynamicResource Main.Tip.Full}">
                    <StackPanel MinWidth="66">
                        <Canvas Width="30" Height="30">
                            <Rectangle Canvas.Left="2" Canvas.Top="4" Width="26" Height="18" RadiusX="3" RadiusY="3"
                                       Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8"/>
                            <Line X1="15" Y1="22" X2="15" Y2="26" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8"/>
                            <Line X1="9" Y1="26.5" X2="21" Y2="26.5" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8"/>
                        </Canvas>
                        <TextBlock Text="{DynamicResource Main.Full}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        <TextBlock x:Name="LblFullKey" Text="-" FontSize="10" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,1,0,0" MaxWidth="86" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Button>

                <!-- 스크롤 캡처 -->
                <Button x:Name="BtnScroll" Style="{StaticResource CaptureButton}" Padding="8,3"
                        Click="ScrollCapture_Click" ToolTip="{DynamicResource Main.Tip.Scroll}">
                    <StackPanel MinWidth="66">
                        <Canvas Width="30" Height="30">
                            <Rectangle Canvas.Left="5" Canvas.Top="2" Width="20" Height="26" RadiusX="3" RadiusY="3"
                                       Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8"/>
                            <Line X1="9" Y1="8" X2="21" Y2="8" Stroke="#9AA6B8" StrokeThickness="1.6"/>
                            <Line X1="9" Y1="12" X2="21" Y2="12" Stroke="#9AA6B8" StrokeThickness="1.6"/>
                            <Path Data="M15,15 L15,24 M11.5,20.5 L15,24 L18.5,20.5"
                                  Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8" Fill="Transparent"/>
                        </Canvas>
                        <TextBlock Text="{DynamicResource Main.Scroll}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        <TextBlock x:Name="LblScrollKey" Text="-" FontSize="10" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,1,0,0" MaxWidth="86" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Button>

                <!-- 고정 크기 캡처 -->
                <Button x:Name="BtnFixed" Style="{StaticResource CaptureButton}" Padding="8,3"
                        Click="FixedCapture_Click" ToolTip="{DynamicResource Main.Tip.Fixed}">
                    <StackPanel MinWidth="66">
                        <Canvas Width="30" Height="30">
                            <Path Data="M2,8 L2,3 L8,3 M22,3 L28,3 L28,8 M28,20 L28,25 L22,25 M8,25 L2,25 L2,20"
                                  Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8" Fill="Transparent"/>
                            <Rectangle Canvas.Left="7" Canvas.Top="8" Width="16" Height="12" RadiusX="1.5" RadiusY="1.5"
                                       Stroke="#9AA6B8" StrokeThickness="1.6" StrokeDashArray="2.4 1.8"/>
                        </Canvas>
                        <TextBlock Text="{DynamicResource Main.Fixed}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        <TextBlock x:Name="LblFixedKey" Text="-" FontSize="10" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,1,0,0" MaxWidth="86" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Button>

                <!-- 캡처 목록 -->
                <Button x:Name="BtnHistory" Style="{StaticResource CaptureButton}" Padding="8,3"
                        Click="History_Click" ToolTip="{DynamicResource Main.Tip.History}">
                    <StackPanel MinWidth="66">
                        <Canvas Width="30" Height="30">
                            <Rectangle Canvas.Left="7" Canvas.Top="2" Width="20" Height="16" RadiusX="2" RadiusY="2"
                                       Stroke="#9AA6B8" StrokeThickness="1.6"/>
                            <Rectangle Canvas.Left="4.5" Canvas.Top="6" Width="20" Height="16" RadiusX="2" RadiusY="2"
                                       Stroke="#5E7FB8" StrokeThickness="1.6" Fill="White"/>
                            <Rectangle Canvas.Left="2" Canvas.Top="10" Width="20" Height="16" RadiusX="2" RadiusY="2"
                                       Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8" Fill="White"/>
                            <Path Data="M5,21 L9,16 L12,19 L15,14 L19,21"
                                  Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                        </Canvas>
                        <TextBlock Text="{DynamicResource Main.History}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        <TextBlock x:Name="LblHistoryCount" Text="0" FontSize="10" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                    </StackPanel>
                </Button>

                <Rectangle Width="1" Height="56" Fill="{StaticResource BorderSoft}" Margin="6,0"/>

                <!-- 지연 캡처 -->
                <StackPanel VerticalAlignment="Center" Margin="2,0,0,0" ToolTip="{DynamicResource Main.Tip.Delay}">
                    <TextBlock Text="{DynamicResource Main.Delay}" FontSize="11" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center"/>
                    <ComboBox x:Name="CmbDelay" Width="78" Margin="0,5,0,0" FontSize="12"
                              SelectionChanged="Delay_Changed">
                        <ComboBoxItem Content="{DynamicResource Main.DelayNow}"/>
                        <ComboBoxItem Content="{DynamicResource Main.Delay3}"/>
                        <ComboBoxItem Content="{DynamicResource Main.Delay5}"/>
                        <ComboBoxItem Content="{DynamicResource Main.Delay10}"/>
                    </ComboBox>
                </StackPanel>

                <Rectangle Width="1" Height="56" Fill="{StaticResource BorderSoft}" Margin="6,0"/>

                <StackPanel VerticalAlignment="Center">
                    <Button x:Name="BtnFolder" Style="{StaticResource IconButton}" Click="OpenFolder_Click"
                            ToolTip="{DynamicResource Main.Tip.Folder}" HorizontalAlignment="Center">
                        <Path Data="M1,4 C1,3 1.7,2.2 2.7,2.2 L6.5,2.2 L8.3,4.2 L15,4.2 C16,4.2 16.7,5 16.7,6 L16.7,12.4 C16.7,13.4 16,14.2 15,14.2 L2.7,14.2 C1.7,14.2 1,13.4 1,12.4 Z"
                              Stroke="{StaticResource TextSub}" StrokeThickness="1.5" Fill="Transparent" Width="18" Height="16"/>
                    </Button>
                    <Button x:Name="BtnSettings" Style="{StaticResource IconButton}" Click="Settings_Click"
                            ToolTip="{DynamicResource Main.Tip.Settings}" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <!-- 톱니바퀴 (코그) 아이콘 -->
                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                              Fill="{StaticResource TextSub}" Width="17" Height="17" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- ── 하단 안내 ── -->
            <Border Grid.Row="2" Background="#F2F6FC" CornerRadius="0,0,13,13">
                <TextBlock x:Name="TxtHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource TextSub}"
                           Text="{DynamicResource Main.Hint.Default}"/>
            </Border>
        </Grid>
    </Border>
</Window>
