<Window x:Class="CaptureIt.ViewfinderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CaptureIt Frame"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual"
        MinWidth="310" MinHeight="150"
        FontFamily="Malgun Gothic" UseLayoutRounding="True"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 캡처 프레임 ── -->
        <Grid Grid.Row="0">
            <!-- 가장자리 히트 스트립: 거의 투명하지만 히트 테스트가 잡혀 크기 조절이 가능하다.
                 중앙은 완전 투명(배경 없음)이라 클릭이 아래 앱으로 통과한다.
                 하단 스트립은 창 바닥(칩 영역)과 떨어져 있어 WM_NCLBUTTONDOWN으로 직접 리사이즈를 시작한다. -->
            <Border Background="#01FFFFFF" Height="12" VerticalAlignment="Top"
                    Cursor="SizeNS" Tag="top" MouseLeftButtonDown="Edge_MouseDown"/>
            <Border Background="#01FFFFFF" Height="12" VerticalAlignment="Bottom"
                    Cursor="SizeNS" Tag="bottom" MouseLeftButtonDown="Edge_MouseDown"/>
            <Border Background="#01FFFFFF" Width="12" HorizontalAlignment="Left"
                    Cursor="SizeWE" Tag="left" MouseLeftButtonDown="Edge_MouseDown"/>
            <Border Background="#01FFFFFF" Width="12" HorizontalAlignment="Right"
                    Cursor="SizeWE" Tag="right" MouseLeftButtonDown="Edge_MouseDown"/>

            <!-- 보이는 프레임 (표시 전용). 그림자·둥근 모서리는 캡처 영역 안쪽으로
                 번져 결과물에 찍히므로 쓰지 않는다 — 또렷한 직사각 테두리만. -->
            <Border BorderBrush="#2D7DF6" BorderThickness="3" Margin="6" IsHitTestVisible="False"/>

            <!-- 실제 캡처되는 안쪽 영역 (좌표 계산용, 렌더링 없음) -->
            <Grid x:Name="InnerArea" Margin="9" IsHitTestVisible="False"/>

            <!-- 꼭지점 원형 핸들: 여기서 대각선으로 끌어 크기를 조절한다 -->
            <Ellipse Width="16" Height="16" Fill="White" Stroke="#2D7DF6" StrokeThickness="2.4"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-1,-1,0,0"
                     Cursor="SizeNWSE" Tag="13" MouseLeftButtonDown="Corner_MouseDown"/>
            <Ellipse Width="16" Height="16" Fill="White" Stroke="#2D7DF6" StrokeThickness="2.4"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-1,-1,0"
                     Cursor="SizeNESW" Tag="14" MouseLeftButtonDown="Corner_MouseDown"/>
            <Ellipse Width="16" Height="16" Fill="White" Stroke="#2D7DF6" StrokeThickness="2.4"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-1,0,0,-1"
                     Cursor="SizeNESW" Tag="16" MouseLeftButtonDown="Corner_MouseDown"/>
            <Ellipse Width="16" Height="16" Fill="White" Stroke="#2D7DF6" StrokeThickness="2.4"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-1,-1"
                     Cursor="SizeNWSE" Tag="17" MouseLeftButtonDown="Corner_MouseDown"/>
        </Grid>

        <!-- ── 컨트롤 칩 ── -->
        <Border x:Name="Chip" Grid.Row="1" HorizontalAlignment="Center" Margin="0,6,0,0"
                Background="#F21F2937" CornerRadius="10" Padding="10,7" Cursor="SizeAll"
                MouseLeftButtonDown="Chip_MouseDown" ToolTip="{DynamicResource Viewfinder.Tip}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.4" Color="#1F2937"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 드래그 안내 점 -->
                <Canvas Width="10" Height="14" Margin="0,0,8,0">
                    <Ellipse Canvas.Left="0" Canvas.Top="1" Width="3" Height="3" Fill="#8CA0B8"/>
                    <Ellipse Canvas.Left="6" Canvas.Top="1" Width="3" Height="3" Fill="#8CA0B8"/>
                    <Ellipse Canvas.Left="0" Canvas.Top="6" Width="3" Height="3" Fill="#8CA0B8"/>
                    <Ellipse Canvas.Left="6" Canvas.Top="6" Width="3" Height="3" Fill="#8CA0B8"/>
                    <Ellipse Canvas.Left="0" Canvas.Top="11" Width="3" Height="3" Fill="#8CA0B8"/>
                    <Ellipse Canvas.Left="6" Canvas.Top="11" Width="3" Height="3" Fill="#8CA0B8"/>
                </Canvas>

                <TextBox x:Name="WBox" Width="54" FontSize="12" Padding="3,2" TextAlignment="Center"
                         VerticalContentAlignment="Center" BorderThickness="0"
                         Background="White" Foreground="#1F2937"
                         KeyDown="SizeBox_KeyDown" LostFocus="SizeBox_LostFocus"/>
                <TextBlock Text="×" Foreground="White" FontSize="12" Margin="6,0" VerticalAlignment="Center"/>
                <TextBox x:Name="HBox" Width="54" FontSize="12" Padding="3,2" TextAlignment="Center"
                         VerticalContentAlignment="Center" BorderThickness="0"
                         Background="White" Foreground="#1F2937"
                         KeyDown="SizeBox_KeyDown" LostFocus="SizeBox_LostFocus"/>

                <Button x:Name="BtnCapture" Margin="12,0,0,0" Cursor="Hand" Padding="14,4"
                        Click="Capture_Click" FontSize="12" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#22C55E" CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Stroke="White" StrokeThickness="1.6" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Viewfinder.Capture}" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnClose" Margin="8,0,0,0" Cursor="Hand" Padding="7,4"
                        Click="Close_Click" ToolTip="Esc">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#3D5A80" CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#EF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Path Data="M0,0 L8,8 M8,0 L0,8" Stroke="White" StrokeThickness="1.5" Width="8" Height="8"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
