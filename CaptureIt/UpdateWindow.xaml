<Window x:Class="CaptureIt.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Update.Title}" Width="440" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}" ShowInTaskbar="True" Topmost="True"
        FontFamily="Malgun Gothic" UseLayoutRounding="True">
    <Border Background="{StaticResource CardBg}" Margin="14" CornerRadius="12"
            BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" Padding="22,18">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <!-- 로고 -->
                <Border Width="34" Height="34" CornerRadius="8" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.6,1">
                            <GradientStop Color="#3F8CF8" Offset="0"/>
                            <GradientStop Color="#1E5FCC" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="22" Height="22">
                            <Border Canvas.Left="8.1" Canvas.Top="4.9" Width="5.8" Height="3.6"
                                    Background="White" CornerRadius="1.2,1.2,0,0"/>
                            <Border Canvas.Left="3.5" Canvas.Top="7.2" Width="15" Height="10"
                                    Background="White" CornerRadius="2.6"/>
                            <Ellipse Canvas.Left="7.2" Canvas.Top="8.9" Width="6.6" Height="6.6" Fill="#1B57C9"/>
                            <Ellipse Canvas.Left="8.3" Canvas.Top="9.9" Width="2.5" Height="2.5" Fill="#7FB0F7"/>
                            <Ellipse Canvas.Left="14.9" Canvas.Top="8.9" Width="2" Height="2" Fill="#FACC15"/>
                        </Canvas>
                    </Viewbox>
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtHeadline" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextMain}"/>
                    <TextBlock x:Name="TxtVersions" FontSize="12" Foreground="{StaticResource TextSub}" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>

            <TextBlock x:Name="LnkNotes" Margin="0,14,0,0" FontSize="12">
                <Hyperlink x:Name="NotesLink" Click="Notes_Click">
                    <Run x:Name="NotesRun"/>
                </Hyperlink>
            </TextBlock>

            <!-- 다운로드 진행 -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,14,0,0">
                <ProgressBar x:Name="Progress" Height="8" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="TxtProgress" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,6,0,0"/>
            </StackPanel>

            <TextBlock x:Name="TxtError" Visibility="Collapsed" Margin="0,12,0,0" FontSize="12"
                       Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"/>

            <Grid Margin="0,18,0,0">
                <Button x:Name="BtnSkip" Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                        Click="Skip_Click">
                    <TextBlock x:Name="TxtSkip" FontSize="12"/>
                </Button>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnLater" Style="{StaticResource GhostButton}" Click="Later_Click">
                        <TextBlock x:Name="TxtLater" FontSize="12"/>
                    </Button>
                    <Button x:Name="BtnUpdate" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Click="Update_Click">
                        <TextBlock x:Name="TxtUpdate" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</Window>
